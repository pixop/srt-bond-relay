{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.4.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "Path Ready",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "max(srt_relay_path_ready{instance=~\"$relay_instance\"})",
          "legendFormat": "ready",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Active Input Index",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "max(srt_relay_active_input_index{instance=~\"$relay_instance\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "stat",
      "title": "Input Switches (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "round(sum(increase(srt_relay_input_switches_total{instance=~\"$relay_instance\"}[5m])))",
          "legendFormat": "switches",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      }
    },
    {
      "type": "stat",
      "title": "Switch Mode",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "max by (mode) (srt_relay_switch_mode{instance=~\"$relay_instance\"} == 1)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "name"
      }
    },
    {
      "type": "timeseries",
      "title": "Relay Throughput",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(srt_relay_rx_bytes_per_sec{instance=~\"$relay_instance\"}) * 8",
          "legendFormat": "RX bps",
          "refId": "A"
        },
        {
          "expr": "sum(srt_relay_tx_bytes_per_sec{instance=~\"$relay_instance\"}) * 8",
          "legendFormat": "TX bps",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bps", "decimals": 0 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Per-Input Connected State",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "srt_relay_input_source_connected{instance=~\"$relay_instance\"}",
          "legendFormat": "input{{input_index}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1 },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Input Policy And Primary",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "max by (policy) (srt_relay_switch_policy{instance=~\"$relay_instance\"})",
          "legendFormat": "policy={{policy}}",
          "refId": "A"
        },
        {
          "expr": "max(srt_relay_primary_input_index{instance=~\"$relay_instance\"})",
          "legendFormat": "primary_index",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Input Bond Mode By Source",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "srt_relay_input_source_bond_mode{instance=~\"$relay_instance\"}",
          "legendFormat": "input{{input_index}} {{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Session States",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "max(srt_relay_input_connected{instance=~\"$relay_instance\"})",
          "legendFormat": "input_connected",
          "refId": "A"
        },
        {
          "expr": "max(srt_relay_output_connected{instance=~\"$relay_instance\"})",
          "legendFormat": "output_connected",
          "refId": "B"
        },
        {
          "expr": "max(srt_relay_path_ready{instance=~\"$relay_instance\"})",
          "legendFormat": "path_ready",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1 },
        "overrides": []
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["srt", "relay", "switched-input"],
  "templating": {
    "list": [
      {
        "name": "relay_instance",
        "type": "query",
        "hide": 0,
        "label": "relay_instance",
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "definition": "label_values(srt_relay_path_ready, instance)",
        "query": {
          "query": "label_values(srt_relay_path_ready, instance)",
          "refId": "PromVar"
        },
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": {
          "selected": false,
          "text": "All",
          "value": ".*"
        }
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "SRT Relay - Switched Input to Single Output",
  "uid": "srt-relay-switched-ops",
  "version": 1,
  "weekStart": ""
}
